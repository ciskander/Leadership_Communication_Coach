{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/mvp.v0.4.0.json",
  "title": "Leadership Coaching Analysis Output (mvp.v0.4.0)",
  "description": "Reasoning-aligned schema: output order follows reasoning order (OEs -> evidence -> scoring -> detection -> coaching).",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "meta",
    "context",
    "opportunity_events",
    "evidence_spans",
    "evaluation_summary",
    "pattern_snapshot",
    "experiment_tracking",
    "coaching"
  ],
  "properties": {
    "schema_version": {
      "const": "mvp.v0.4.0"
    },
    "meta": {
      "$ref": "#/$defs/Meta"
    },
    "context": {
      "oneOf": [
        { "$ref": "#/$defs/SingleMeetingContext" },
        { "$ref": "#/$defs/BaselinePackContext" }
      ]
    },
    "opportunity_events": {
      "type": "array",
      "minItems": 0,
      "items": {
        "$ref": "#/$defs/OpportunityEvent"
      }
    },
    "evidence_spans": {
      "type": "array",
      "minItems": 0,
      "items": {
        "$ref": "#/$defs/EvidenceSpan"
      }
    },
    "evaluation_summary": {
      "$ref": "#/$defs/EvaluationSummary"
    },
    "pattern_snapshot": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/PatternMeasurementUnion"
      }
    },
    "experiment_tracking": {
      "$ref": "#/$defs/ExperimentTracking"
    },
    "coaching": {
      "$ref": "#/$defs/Coaching"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "meta": {
            "properties": { "analysis_type": { "const": "single_meeting" } },
            "required": ["analysis_type"]
          }
        }
      },
      "then": {
        "properties": {
          "context": { "$ref": "#/$defs/SingleMeetingContext" },
          "experiment_tracking": { "$ref": "#/$defs/ExperimentTrackingSingleMeeting" }
        }
      }
    },
    {
      "if": {
        "properties": {
          "meta": {
            "properties": { "analysis_type": { "const": "baseline_pack" } },
            "required": ["analysis_type"]
          }
        }
      },
      "then": {
        "properties": {
          "context": { "$ref": "#/$defs/BaselinePackContext" },
          "experiment_tracking": { "$ref": "#/$defs/ExperimentTrackingBaselinePack" }
        }
      }
    }
  ],
  "$defs": {
    "Meta": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "analysis_id",
        "analysis_type",
        "generated_at",
        "taxonomy_version",
        "output_mode"
      ],
      "properties": {
        "analysis_id": {
          "type": "string",
          "pattern": "^A-[0-9]{6}$"
        },
        "analysis_type": {
          "type": "string",
          "enum": ["single_meeting", "baseline_pack"]
        },
        "generated_at": {
          "type": "string",
          "format": "date-time"
        },
        "taxonomy_version": {
          "type": "string",
          "const": "v3.0"
        },
        "output_mode": {
          "type": "string",
          "const": "coaching_first_2s1e"
        },
        "schema_hash": {
          "type": ["string", "null"]
        },
        "meeting_id": {
          "type": ["string", "null"],
          "pattern": "^M-[0-9]{6}$"
        },
        "baseline_pack_id": {
          "type": ["string", "null"],
          "pattern": "^BP-[0-9]{6}$"
        }
      }
    },
    "SingleMeetingContext": {
      "type": "object",
      "additionalProperties": false,
      "required": ["meeting_id", "meeting_type", "target_role"],
      "properties": {
        "meeting_id": {
          "type": "string",
          "pattern": "^M-[0-9]{6}$"
        },
        "meeting_type": {
          "type": "string",
          "enum": [
            "exec_staff", "board", "all_hands", "cross_functional",
            "project_review", "sprint_planning", "sprint_retrospective",
            "stand_up", "incident_review", "client_call", "one_on_one", "other"
          ]
        },
        "target_speaker_name": { "type": "string" },
        "target_speaker_label": { "type": "string" },
        "target_role": {
          "type": "string",
          "enum": ["chair", "presenter", "participant", "manager_1to1", "report_1to1"]
        },
        "meeting_date": { "type": ["string", "null"] }
      }
    },
    "BaselinePackContext": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "baseline_pack_id", "pack_size", "target_role",
        "role_consistency", "meeting_type_consistency", "meetings"
      ],
      "properties": {
        "baseline_pack_id": {
          "type": "string",
          "pattern": "^BP-[0-9]{6}$"
        },
        "pack_size": { "type": "integer", "minimum": 1, "maximum": 20 },
        "target_role": {
          "type": "string",
          "enum": ["chair", "presenter", "participant", "manager_1to1", "report_1to1", "mixed"]
        },
        "role_consistency": { "type": "boolean" },
        "meeting_type_consistency": { "type": "boolean" },
        "meetings": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["meeting_id", "meeting_type"],
            "properties": {
              "meeting_id": { "type": "string", "pattern": "^M-[0-9]{6}$" },
              "meeting_type": {
                "type": "string",
                "enum": [
                  "exec_staff", "board", "all_hands", "cross_functional",
                  "project_review", "sprint_planning", "sprint_retrospective",
                  "stand_up", "incident_review", "client_call", "one_on_one", "other"
                ]
              }
            }
          }
        }
      }
    },
    "PatternId": {
      "type": "string",
      "enum": [
        "purposeful_framing", "focus_management", "participation_management",
        "disagreement_navigation", "resolution_and_alignment", "assignment_clarity",
        "question_quality", "communication_clarity", "feedback_quality"
      ]
    },
    "ClusterId": {
      "type": "string",
      "enum": ["meeting_structure", "participation_dynamics", "decisions_accountability", "communication_quality"]
    },
    "ScoringType": {
      "type": "string",
      "enum": ["dual_element", "tiered_rubric", "binary", "three_tier", "complexity_tiered", "multi_element"]
    },

    "OpportunityEvent": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "event_id", "pattern_id", "turn_start_id", "turn_end_id",
        "target_control", "count_decision", "success", "reason_code"
      ],
      "properties": {
        "event_id": {
          "type": "string",
          "pattern": "^OE-[0-9]{3}$"
        },
        "pattern_id": { "$ref": "#/$defs/PatternId" },
        "turn_start_id": { "type": "integer", "minimum": 1 },
        "turn_end_id": { "type": "integer", "minimum": 1 },
        "target_control": {
          "type": "string",
          "enum": ["yes", "no", "unclear"]
        },
        "count_decision": {
          "type": "string",
          "enum": ["counted", "excluded"]
        },
        "success": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "reason_code": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*$"
        },
        "notes": { "type": ["string", "null"] }
      }
    },

    "EvidenceSpan": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "evidence_span_id", "turn_start_id", "turn_end_id", "excerpt", "event_ids"
      ],
      "properties": {
        "evidence_span_id": {
          "type": "string",
          "pattern": "^ES-T[0-9]+(-[0-9]+)?$"
        },
        "turn_start_id": { "type": "integer", "minimum": 1 },
        "turn_end_id": { "type": "integer", "minimum": 1 },
        "excerpt": {
          "type": "string",
          "minLength": 1,
          "maxLength": 2000
        },
        "event_ids": {
          "type": "array",
          "minItems": 0,
          "items": {
            "type": "string",
            "pattern": "^OE-[0-9]{3}$"
          },
          "uniqueItems": true
        },
        "meeting_id": {
          "type": ["string", "null"],
          "pattern": "^M-[0-9]{6}$"
        },
        "speaker_role": {
          "type": ["string", "null"],
          "enum": ["chair", "presenter", "participant", "manager_1to1", "report_1to1", null]
        }
      }
    },

    "EvaluationSummary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "patterns_evaluated",
        "patterns_insufficient_signal",
        "patterns_not_evaluable"
      ],
      "properties": {
        "patterns_evaluated": {
          "type": "array",
          "items": { "$ref": "#/$defs/PatternId" },
          "uniqueItems": true
        },
        "patterns_insufficient_signal": {
          "type": "array",
          "items": { "$ref": "#/$defs/PatternId" },
          "uniqueItems": true
        },
        "patterns_not_evaluable": {
          "type": "array",
          "items": { "$ref": "#/$defs/PatternId" },
          "uniqueItems": true
        }
      }
    },

    "PatternMeasurementBase": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "pattern_id", "cluster_id", "scoring_type", "evaluable_status",
        "denominator_rule_id", "min_required_threshold", "evidence_span_ids"
      ],
      "properties": {
        "pattern_id": { "$ref": "#/$defs/PatternId" },
        "cluster_id": { "$ref": "#/$defs/ClusterId" },
        "scoring_type": { "$ref": "#/$defs/ScoringType" },
        "evaluable_status": {
          "type": "string",
          "enum": ["evaluable", "insufficient_signal", "not_evaluable"]
        },
        "denominator_rule_id": { "type": "string", "minLength": 1 },
        "min_required_threshold": {
          "type": ["number", "null"],
          "minimum": 0
        },
        "score": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "opportunity_count": {
          "type": ["integer", "null"],
          "minimum": 0
        },
        "element_a_count": { "type": ["integer", "null"], "minimum": 0 },
        "element_b_count": { "type": ["integer", "null"], "minimum": 0 },
        "simple_count": { "type": ["integer", "null"], "minimum": 0 },
        "complex_count": { "type": ["integer", "null"], "minimum": 0 },
        "balance_assessment": {
          "type": "string",
          "enum": ["over_indexed", "balanced", "under_indexed", "unclear"]
        },
        "evidence_span_ids": {
          "type": "array",
          "minItems": 0,
          "items": {
            "type": "string",
            "pattern": "^ES-T[0-9]+(-[0-9]+)?$"
          },
          "uniqueItems": true
        },
        "success_evidence_span_ids": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^ES-T[0-9]+(-[0-9]+)?$"
          },
          "uniqueItems": true
        }
      }
    },

    "PatternMeasurementEvaluable": {
      "allOf": [
        { "$ref": "#/$defs/PatternMeasurementBase" },
        {
          "type": "object",
          "required": ["score", "opportunity_count"],
          "properties": {
            "evaluable_status": { "const": "evaluable" },
            "opportunity_count": { "type": "integer", "minimum": 1 }
          }
        }
      ]
    },
    "PatternMeasurementEvaluableAggregate": {
      "allOf": [
        { "$ref": "#/$defs/PatternMeasurementBase" },
        {
          "type": "object",
          "required": ["score"],
          "properties": {
            "evaluable_status": { "const": "evaluable" },
            "denominator_rule_id": { "const": "weighted_average_of_meeting_level_scores" }
          }
        }
      ]
    },
    "PatternMeasurementInsufficientSignal": {
      "allOf": [
        { "$ref": "#/$defs/PatternMeasurementBase" },
        {
          "type": "object",
          "properties": {
            "evaluable_status": { "const": "insufficient_signal" }
          },
          "not": {
            "anyOf": [
              { "required": ["score"] }
            ]
          }
        }
      ]
    },
    "PatternMeasurementNotEvaluable": {
      "allOf": [
        { "$ref": "#/$defs/PatternMeasurementBase" },
        {
          "type": "object",
          "properties": {
            "evaluable_status": { "const": "not_evaluable" }
          },
          "not": {
            "anyOf": [
              { "required": ["score"] }
            ]
          }
        }
      ]
    },
    "PatternMeasurementUnion": {
      "oneOf": [
        { "$ref": "#/$defs/PatternMeasurementEvaluable" },
        { "$ref": "#/$defs/PatternMeasurementEvaluableAggregate" },
        { "$ref": "#/$defs/PatternMeasurementInsufficientSignal" },
        { "$ref": "#/$defs/PatternMeasurementNotEvaluable" }
      ]
    },

    "HighlightItem": {
      "type": "object",
      "additionalProperties": false,
      "required": ["pattern_id", "message"],
      "properties": {
        "pattern_id": { "$ref": "#/$defs/PatternId" },
        "message": { "type": "string", "minLength": 1, "maxLength": 800 }
      }
    },
    "MicroExperiment": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "experiment_id", "title", "instruction", "success_marker",
        "pattern_id", "evidence_span_ids"
      ],
      "properties": {
        "experiment_id": { "type": "string", "pattern": "^EXP-[0-9]{6}$" },
        "title": { "type": "string", "minLength": 1, "maxLength": 140 },
        "instruction": { "type": "string", "minLength": 1, "maxLength": 600 },
        "success_marker": { "type": "string", "minLength": 1, "maxLength": 300 },
        "pattern_id": { "$ref": "#/$defs/PatternId" },
        "evidence_span_ids": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^ES-T[0-9]+(-[0-9]+)?$"
          },
          "uniqueItems": true
        }
      }
    },
    "PatternCoachingItem": {
      "type": "object",
      "additionalProperties": false,
      "required": ["pattern_id"],
      "properties": {
        "pattern_id": { "$ref": "#/$defs/PatternId" },
        "notes": { "type": ["string", "null"] },
        "coaching_note": { "type": ["string", "null"], "maxLength": 800 },
        "suggested_rewrite": { "type": ["string", "null"], "maxLength": 1000 },
        "rewrite_for_span_id": {
          "type": ["string", "null"],
          "pattern": "^ES-T[0-9]+(-[0-9]+)?$"
        }
      }
    },
    "ExperimentCoaching": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "coaching_note": { "type": ["string", "null"], "maxLength": 800 },
        "suggested_rewrite": { "type": ["string", "null"], "maxLength": 1000 },
        "rewrite_for_span_id": {
          "type": ["string", "null"],
          "pattern": "^ES-T[0-9]+(-[0-9]+)?$"
        }
      }
    },
    "Coaching": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "executive_summary", "strengths", "focus", "micro_experiment",
        "pattern_coaching"
      ],
      "properties": {
        "executive_summary": {
          "type": "string",
          "minLength": 1,
          "maxLength": 1200
        },
        "strengths": {
          "type": "array",
          "minItems": 0,
          "maxItems": 2,
          "items": { "$ref": "#/$defs/HighlightItem" }
        },
        "focus": {
          "type": "array",
          "minItems": 1,
          "maxItems": 1,
          "items": { "$ref": "#/$defs/HighlightItem" }
        },
        "micro_experiment": {
          "type": "array",
          "minItems": 1,
          "maxItems": 1,
          "items": { "$ref": "#/$defs/MicroExperiment" }
        },
        "pattern_coaching": {
          "type": "array",
          "minItems": 0,
          "items": { "$ref": "#/$defs/PatternCoachingItem" }
        },
        "experiment_coaching": {
          "oneOf": [
            { "$ref": "#/$defs/ExperimentCoaching" },
            { "type": "null" }
          ]
        }
      }
    },

    "ActiveExperiment": {
      "type": "object",
      "additionalProperties": false,
      "required": ["experiment_id", "status"],
      "properties": {
        "experiment_id": {
          "type": ["string", "null"],
          "pattern": "^EXP-[0-9]{6}$"
        },
        "status": {
          "type": "string",
          "enum": ["none", "proposed", "active", "completed", "abandoned"]
        }
      }
    },
    "ExperimentDetection": {
      "type": "object",
      "additionalProperties": false,
      "required": ["experiment_id", "attempt", "count_attempts", "evidence_span_ids"],
      "properties": {
        "experiment_id": { "type": "string", "pattern": "^EXP-[0-9]{6}$" },
        "attempt": { "type": "string", "enum": ["no", "partial", "yes"] },
        "count_attempts": { "type": "integer", "minimum": 0 },
        "evidence_span_ids": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^ES-T[0-9]+(-[0-9]+)?$"
          },
          "uniqueItems": true
        }
      }
    },
    "ExperimentTracking": {
      "type": "object",
      "additionalProperties": false,
      "required": ["active_experiment", "detection_in_this_meeting"],
      "properties": {
        "active_experiment": { "$ref": "#/$defs/ActiveExperiment" },
        "detection_in_this_meeting": {
          "oneOf": [
            { "$ref": "#/$defs/ExperimentDetection" },
            { "type": "null" }
          ]
        }
      }
    },
    "ExperimentTrackingSingleMeeting": {
      "allOf": [
        { "$ref": "#/$defs/ExperimentTracking" },
        {
          "if": {
            "properties": {
              "active_experiment": {
                "properties": { "status": { "enum": ["proposed", "active"] } },
                "required": ["status"]
              }
            }
          },
          "then": {
            "properties": {
              "detection_in_this_meeting": { "$ref": "#/$defs/ExperimentDetection" }
            }
          },
          "else": {
            "properties": {
              "detection_in_this_meeting": {
                "oneOf": [
                  { "$ref": "#/$defs/ExperimentDetection" },
                  { "type": "null" }
                ]
              }
            }
          }
        }
      ]
    },
    "ExperimentTrackingBaselinePack": {
      "allOf": [
        { "$ref": "#/$defs/ExperimentTracking" },
        {
          "properties": {
            "detection_in_this_meeting": { "type": "null" }
          }
        }
      ]
    }
  }
}
